# Experimental mapping-only extrinsics candidate.
# Source: user-provided test values for controlled RTAB-Map comparison.

EXTRINSICS_PROFILE="test_candidate_v1"

# Camera source should come from URDF/robot_state_publisher to avoid creating
# a second parent for camera_link when board_description is running.
CAMERA_TF_SOURCE="urdf"
CAMERA_FRAME="camera_link"
CAMERA_XYZ="0.2203 0 0.1225"
CAMERA_RPY="0 0.05 0"

# Canonical project LiDAR frame. Legacy runtime publishers may still emit
# /utlidar/cloud with frame_id=utlidar_lidar, but the project-side TF target is
# now lidar_frame.
LIDAR_FRAME="lidar_frame"
LIDAR_XYZ="0.0018320158435115 0.000108320625906232 0.253633251213134"
LIDAR_RPY="0 0 0"
