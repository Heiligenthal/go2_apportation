\section{\texttt{rtabmap\_params.yaml} (Baseline)}
\label{app:rtabmap_params}
\begin{lstlisting}[style=yamlcontracts, language=yaml,caption={Baseline RTAB-Map Parameterdatei (RGB-D SLAM, map->odom).}]
# file: rtabmap_params.yaml
# Baseline RTAB-Map config for RGB-D SLAM (Intel RealSense D415) on Unitree Go2 EDU.
#
# Goal: provide localization TF map->odom, using Go2 odom->base_link.
# LiDAR deskewed cloud is OPTIONAL (can improve obstacle representation / mapping), but baseline is RGB-D.
#
#
# Frames:
#   base_frame_id: base_link
#   odom_frame_id: odom
#   map_frame_id:  map
#   TF map->odom will be published by RTAB-Map (publish_tf: true)

# ----------------------------
# Option A (recommended): use rgbd_sync + rtabmap node
#   rgbd_sync creates /rgbd_image from RGB+Depth+CameraInfo with approx sync
#   rtabmap subscribes to /rgbd_image and /odom
# ----------------------------

rgbd_sync:
  ros__parameters:
    use_sim_time: false
    approx_sync: true
    queue_size: 30
    # Inputs
    rgb_topic: "(*@\RgbTopic@*)"
    depth_topic: "(*@\DepthTopic@*)"
    camera_info_topic: "(*@\CameraInfoTopic@*)"
    # Output
    rgbd_image: "/rgbd_image"   # default name; keep stable for docs

rtabmap:
  ros__parameters:
    use_sim_time: false

    # ---- Frames / TF ----
    base_frame_id: "base_link"
    odom_frame_id: "odom"
    map_frame_id: "map"
    publish_tf: true                 # publish TF map->odom
    tf_delay: 0.05
    tf_tolerance: 0.2

    # ---- Subscriptions ----
    subscribe_rgbd: true
    subscribe_depth: false
    subscribe_rgb: false
    subscribe_scan: false
    subscribe_scan_cloud: false      # optional (see below)
    subscribe_imu: false             # optional (see below)
    subscribe_odom_info: false

    # Input topics
    rgbd_image_topic: "/rgbd_image"
    odom_topic: "(*@\OdomTopic@*)"

    # ---- Sync / timing robustness ----
    approx_sync: true
    queue_size: 30
    wait_for_transform: 0.2

    # ---- Database ----
    database_path: "~/.ros/rtabmap.db"

    # ---- Mapping vs Localization ----
    # Mapping mode baseline:
    Mem/IncrementalMemory: "true"
    # For localization-only (use existing map/db), set:
    # Mem/IncrementalMemory: "false"
    # and optionally disable new loop closures:
    # RGBD/LoopClosureReextractFeatures: "false"

    # ---- RealSense D415 practical constraints ----
    # D415 depth is most reliable roughly 0.45m..3.5m (baseline prefilter in driver),
    # but RTAB-Map can also clamp depth:
    RGBD/DepthMin: "0.45"
    RGBD/DepthMax: "3.50"

    # ---- Performance / stability baseline ----
    # Reduce load (especially on embedded CPUs):
    RGBD/LinearUpdate: "0.05"         # meters (add node when moved this much)
    RGBD/AngularUpdate: "0.05"        # rad
    RGBD/OptimizeFromGraphEnd: "false"
    Optimizer/Iterations: "30"

    # Visual features / registration (baseline)
    Reg/Strategy: "1"                 # 0=Visual, 1=ICP, 2=Visual+ICP (varies by builds; baseline keep visual)
    Vis/MinInliers: "12"
    Vis/InlierDistance: "0.10"

    # Occupancy grid output for Nav2
    grid: true
    Grid/FromDepth: "true"
    Grid/3D: "false"                  # 2D occupancy grid for Nav2
    Grid/RangeMax: "4.0"              # Depth grid max range (tune)
    Grid/FootprintRadius: "0.35"      # match nav2 robot_radius baseline

    # If you see “phantom obstacles from depth noise:
    # Grid/NoiseFilteringRadius: "0.05"
    # Grid/NoiseFilteringMinNeighbors: "3"

    # ---- Loop closure (baseline moderate) ----
    RGBD/ProximityBySpace: "true"
    RGBD/ProximityMaxGraphDepth: "50"
    RGBD/ProximityPathMaxNeighbors: "1"
    RGBD/ProximityPathFilteringRadius: "0.5"

    # ---- Logging/debug ----
    Rtabmap/PublishStats: "true"
    Rtabmap/PublishPDF: "false"
    Rtabmap/TimeThr: "0"              # 0 = no time limit

# ----------------------------
# OPTIONAL: add IMU constraint (only if you have stable imu_link TF and good IMU)
# ----------------------------
# imu_filter_madgwick / robot_localization usually handles IMU->orientation.
# RTAB-Map can subscribe to IMU, but baseline is OFF until validated.
#
# rtabmap:
#   ros__parameters:
#     subscribe_imu: true
#     imu_topic: "(*@\ImuTopic@*)"
#     # If IMU orientation is good:
#     # Reg/Force3DoF: "true"   # enforce planar motion (indoor flat floors)
#
# ----------------------------
# OPTIONAL: add LiDAR deskewed cloud for ICP refinement / obstacle integration
# ----------------------------
# This is optional because your nav2 costmap already uses LiDAR.
# If you add it, ensure the cloud frame is transformable to base_link/odom.
#
# rtabmap:
#   ros__parameters:
#     subscribe_scan_cloud: true
#     scan_cloud_topic: "(*@\LidarCloudTopic@*)"
#     # Allow using depth + cloud:
#     Reg/Strategy: "2"          # Visual+ICP (if supported in your build)
#     Icp/VoxelSize: "0.05"
#     Icp/MaxCorrespondenceDistance: "0.5"

\end{lstlisting}

\section{\texttt{realsense.yaml} (Baseline D415)}
\label{app:realsense_params}
\begin{lstlisting}[style=yamlcontracts, language=yaml,caption={Baseline RealSense D415 Parameterdatei (RGB+Depth, align, filtering).}]
# file: realsense.yaml
# Intel RealSense D415 baseline for RGB-D SLAM + perception (ROS2 Humble, realsense2_camera)
#
# Goals:
# - stable RGB + aligned depth
# - depth range constrained to reliable band
# - lightweight filtering (decimation + temporal) for robustness/CPU
#
# IMPORTANT: Parameter names vary slightly by realsense-ros version.
# This YAML is structured in the common ROS2 style for realsense2_camera.
# If a parameter is rejected at runtime, check `ros2 param list` and adjust naming.

realsense2_camera:
  ros__parameters:
    use_sim_time: false

    # ---- Enable streams ----
    enable_color: true
    enable_depth: true
    enable_infra1: false
    enable_infra2: false
    enable_gyro: false
    enable_accel: false

    # ---- Frame rate / resolution (baseline) ----
    # D415 typical stable baseline (adjust if CPU is tight)
    color_width: 640
    color_height: 480
    color_fps: 30

    depth_width: 640
    depth_height: 480
    depth_fps: 30

    # ---- Align depth to color (important for RGB-D pipelines) ----
    align_depth:
      enable: true

    # ---- Depth clamp ----
    # ROS2 wrapper supports depth range via clip distance in some versions:
    clip_distance: 3.5          # meters (max depth); 0 disables
    # Minimum depth is often handled by filtering + consumer side; keep documented baseline:
    # min_depth: 0.45           # if supported; otherwise handle in RTAB-Map and pointcloud filters

    # ---- Pointcloud ----
    pointcloud:
      enable: true
      allow_no_texture_points: false
      ordered_pc: false
    # Depth->PointCloud is heavy; if CPU is tight, disable and only use images for SLAM.
    # For Nav2 costmap you can use LiDAR cloud instead.

    # ---- Post-processing filters ----
    # These filter blocks exist in many realsense-ros versions; naming may differ.
    decimation_filter:
      enable: true
      filter_magnitude: 2        # 2 = downsample by 2

    temporal_filter:
      enable: true
      filter_smooth_alpha: 0.4
      filter_smooth_delta: 20
      holes_fill: 1

    spatial_filter:
      enable: false              # optional (enable if you need more smoothing)
      filter_magnitude: 2
      filter_smooth_alpha: 0.5
      filter_smooth_delta: 20
      holes_fill: 0

    hole_filling_filter:
      enable: false              # optional

    # ---- Exposure/Auto settings ----
    # Default auto exposure is usually fine. Tune only if needed for motion blur.
    # enable_auto_exposure: true

\end{lstlisting}

\section{\texttt{bringup\_minimal.launch.py} (Template)}
\label{app:bringup_launch}
\begin{lstlisting}[style=yamlcontracts, language=Python,caption={Minimaler Bringup Launch (Template) für URDF+TF, RealSense, RTAB-Map, Nav2.}]
# file: bringup_minimal.launch.py
# Minimal bringup plan (ROS2 Humble) for your pipeline:
# - robot_state_publisher (URDF for base_link->sensor frames + arm frames)
# - Unitree bridge (publishes odom->base_link, joint_states, etc.)
# - RealSense driver
# - rgbd_sync + rtabmap
# - Nav2
#
# NOTE: This is a structural template; replace package/executable names with your actual ones.

from launch import LaunchDescription
from launch.actions import DeclareLaunchArgument, IncludeLaunchDescription
from launch.substitutions import LaunchConfiguration, PathJoinSubstitution
from launch.launch_description_sources import PythonLaunchDescriptionSource
from launch_ros.actions import Node
from launch_ros.substitutions import FindPackageShare

def generate_launch_description():
    use_sim_time = LaunchConfiguration("use_sim_time")
    urdf_path = LaunchConfiguration("urdf_path")
    nav2_params = LaunchConfiguration("nav2_params")
    rtabmap_params = LaunchConfiguration("rtabmap_params")
    realsense_params = LaunchConfiguration("realsense_params")

    return LaunchDescription([
        DeclareLaunchArgument("use_sim_time", default_value="false"),
        DeclareLaunchArgument("urdf_path", default_value=""),  # e.g. <your_pkg>/urdf/go2.urdf
        DeclareLaunchArgument("nav2_params", default_value=""), # path to nav2_params.yaml
        DeclareLaunchArgument("rtabmap_params", default_value=""), # path to rtabmap_params.yaml
        DeclareLaunchArgument("realsense_params", default_value=""), # path to realsense.yaml

        # 1) TF static tree from URDF (base_link->camera_link/imu_link/lidar_frame/arm...)
        Node(
            package="robot_state_publisher",
            executable="robot_state_publisher",
            name="robot_state_publisher",
            output="screen",
            parameters=[{
                "use_sim_time": use_sim_time,
                # Use robot_description from file; if you generate via xacro, do it here.
                # "robot_description": Command(["xacro ", urdf_path]),
            }],
            # If you don't use xacro Command, load robot_description in another way.
        ),

        # 2) Unitree bridge / base bringup (placeholder)
        # Replace with your actual Unitree ROS2 bringup launch or node.
        # IncludeLaunchDescription(
        #   PythonLaunchDescriptionSource([FindPackageShare("unitree_go2_bringup"), "/launch/bringup.launch.py"]),
        #   launch_arguments={"use_sim_time": use_sim_time}.items()
        # ),

        # 3) RealSense driver
        Node(
            package="realsense2_camera",
            executable="realsense2_camera_node",
            name="realsense2_camera",
            output="screen",
            parameters=[realsense_params, {"use_sim_time": use_sim_time}],
        ),

        # 4) RTAB-Map: rgbd_sync + rtabmap (assumes these executables exist in rtabmap_ros)
        Node(
            package="rtabmap_sync",
            executable="rgbd_sync",
            name="rgbd_sync",
            output="screen",
            parameters=[rtabmap_params, {"use_sim_time": use_sim_time}],
        ),
        Node(
            package="rtabmap_slam",
            executable="rtabmap",
            name="rtabmap",
            output="screen",
            parameters=[rtabmap_params, {"use_sim_time": use_sim_time}],
        ),

        # 5) Nav2 bringup (nav2_bringup)
        IncludeLaunchDescription(
            PythonLaunchDescriptionSource(
                PathJoinSubstitution([FindPackageShare("nav2_bringup"), "launch", "bringup_launch.py"])
            ),
            launch_arguments={
                "use_sim_time": use_sim_time,
                "params_file": nav2_params,
            }.items(),
        ),
    ])

\end{lstlisting}

