\section{\texttt{nav2\_params.yaml} (Baseline)}
\label{app:nav2_params}
\begin{lstlisting}[style=yamlcontracts, language=yaml,caption={Baseline Nav2 Parameterdatei (Indoor, Voxel Costmap, konservative Limits).}]
# file: nav2_params.yaml
# Baseline Nav2 config for Unitree Go2 EDU (Indoor, RTAB-Map map->odom, Go2 odom->base_link)
#
#
# Frames must exist via TF:
#   map -> odom (rtabmap)
#   odom -> base_link (unitree)
#   base_link -> lidar_frame / camera_link / imu_link (URDF + robot_state_publisher)

# ----------------------------
# Global settings / common
# ----------------------------
# If you use simulation, set use_sim_time true in all nodes.
# Here: real robot baseline.
#
# NOTE: Nav2 expects /tf + /tf_static. Ensure those are present.

bt_navigator:
  ros__parameters:
    use_sim_time: false
    global_frame: map
    robot_base_frame: base_link
    odom_topic: "(*@\OdomTopic@*)"
    bt_loop_duration: 10
    default_server_timeout: 20
    # Use the default NavigateToPose BT if you don't provide a custom XML.
    # default_nav_to_pose_bt_xml: ""  # optional override
    # default_nav_through_poses_bt_xml: ""  # optional override

planner_server:
  ros__parameters:
    use_sim_time: false
    expected_planner_frequency: 5.0
    planner_plugins: ["GridBased"]

    GridBased:
      plugin: "nav2_navfn_planner/NavfnPlanner"
      tolerance: 0.5
      use_astar: false
      allow_unknown: true

controller_server:
  ros__parameters:
    use_sim_time: false
    controller_frequency: 20.0
    odom_topic: "(*@\OdomTopic@*)"

    # Progress / goal checker plugins
    progress_checker_plugins: ["progress_checker"]
    goal_checker_plugins: ["goal_checker"]

    progress_checker:
      plugin: "nav2_controller::PoseProgressChecker"
      required_movement_radius: 0.10
      required_movement_angle: 0.10
      movement_time_allowance: 10.0

    goal_checker:
      plugin: "nav2_controller::SimpleGoalChecker"
      stateful: true
      xy_goal_tolerance: 0.15
      yaw_goal_tolerance: 0.20

    controller_plugins: ["FollowPath"]

    FollowPath:
      plugin: "dwb_core::DWBLocalPlanner"
      debug_trajectory_details: false

      # --- Baseline indoor motion limits (conservative, stable SLAM/perception) ---
      max_vel_x: 0.8
      min_vel_x: 0.0
      max_vel_y: 0.0
      min_vel_y: 0.0
      max_vel_theta: 1.0
      min_vel_theta: -1.0

      acc_lim_x: 0.8
      decel_lim_x: -0.8
      acc_lim_y: 0.0
      decel_lim_y: 0.0
      acc_lim_theta: 1.2
      decel_lim_theta: -1.2

      vx_samples: 10
      vy_samples: 1
      vtheta_samples: 20
      sim_time: 1.7
      linear_granularity: 0.05
      angular_granularity: 0.025
      transform_tolerance: 0.2

      # --- Goal tolerances for navigation (NOT grasp precision) ---
      xy_goal_tolerance: 0.15
      yaw_goal_tolerance: 0.20

      # --- DWB critics (reasonable baseline) ---
      critics:
        - RotateToGoal
        - Oscillation
        - BaseObstacle
        - PathAlign
        - GoalAlign
        - PathDist
        - GoalDist

      BaseObstacle.scale: 0.02
      PathAlign.scale: 32.0
      GoalAlign.scale: 24.0
      PathDist.scale: 32.0
      GoalDist.scale: 24.0
      RotateToGoal.scale: 32.0
      RotateToGoal.slowing_factor: 5.0
      RotateToGoal.lookahead_time: 1.0

smoother_server:
  ros__parameters:
    use_sim_time: false
    smoother_plugins: ["SimpleSmoother"]
    SimpleSmoother:
      plugin: "nav2_smoother::SimpleSmoother"
      tolerance: 1.0e-6
      max_its: 1000
      do_refinement: true

behavior_server:
  ros__parameters:
    use_sim_time: false
    global_frame: map
    robot_base_frame: base_link
    transform_tolerance: 0.2
    cycle_frequency: 10.0

    behavior_plugins:
      - spin
      - backup
      - drive_on_heading
      - wait
      - assisted_teleop

    spin:
      plugin: "nav2_behaviors/Spin"
    backup:
      plugin: "nav2_behaviors/BackUp"
    drive_on_heading:
      plugin: "nav2_behaviors/DriveOnHeading"
    wait:
      plugin: "nav2_behaviors/Wait"
    assisted_teleop:
      plugin: "nav2_behaviors/AssistedTeleop"

waypoint_follower:
  ros__parameters:
    use_sim_time: false
    loop_rate: 5
    stop_on_failure: true
    waypoint_task_executor_plugin: "wait_at_waypoint"
    wait_at_waypoint:
      plugin: "nav2_waypoint_follower::WaitAtWaypoint"
      enabled: true
      waypoint_pause_duration: 0  # seconds

velocity_smoother:
  ros__parameters:
    use_sim_time: false
    smoothing_frequency: 20.0
    scale_velocities: false
    feedback: "OPEN_LOOP"
    max_velocity: [0.8, 0.0, 1.0]     # [x, y, theta]
    min_velocity: [0.0, 0.0, -1.0]
    max_accel: [0.8, 0.0, 1.2]
    max_decel: [-0.8, 0.0, -1.2]
    odom_topic: "(*@\OdomTopic@*)"
    velocity_timeout: 1.0
    cmd_vel_in_topic: "/cmd_vel_nav"           # controller_server -> velocity_smoother (interner Pfad)
    cmd_vel_out_topic: "(*@\CmdVelNavTopic@*)" # Nav2-Ausgang vor Twist-Mux

# ----------------------------
# Costmaps
# ----------------------------

global_costmap:
  global_costmap:
    ros__parameters:
      use_sim_time: false
      global_frame: map
      robot_base_frame: base_link
      transform_tolerance: 0.2
      update_frequency: 5.0
      publish_frequency: 2.0

      resolution: 0.05
      track_unknown_space: true

      # Choose ONE footprint model:
      # Option A: radius (quick start)
      robot_radius: 0.35
      # Option B: explicit footprint (replace radius if used)
      # footprint: "[[0.30, 0.20], [0.30, -0.20], [-0.30, -0.20], [-0.30, 0.20]]"

      plugins: ["static_layer", "inflation_layer"]

      static_layer:
        plugin: "nav2_costmap_2d::StaticLayer"
        map_subscribe_transient_local: true
        subscribe_to_updates: true

      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        inflation_radius: 0.60
        cost_scaling_factor: 5.0

local_costmap:
  local_costmap:
    ros__parameters:
      use_sim_time: false
      global_frame: odom
      robot_base_frame: base_link
      transform_tolerance: 0.2
      update_frequency: 10.0
      publish_frequency: 5.0

      rolling_window: true
      width: 8.0
      height: 8.0
      resolution: 0.05

      # Same footprint model as global
      robot_radius: 0.35
      # footprint: "[[0.30, 0.20], [0.30, -0.20], [-0.30, -0.20], [-0.30, 0.20]]"

      plugins: ["voxel_layer", "inflation_layer"]

      voxel_layer:
        plugin: "nav2_costmap_2d::VoxelLayer"
        enabled: true
        footprint_clearing_enabled: true

        # Debug visualization in RViz (can be noisy; keep on initially)
        publish_voxel_map: true

        # 3D voxel grid parameters (indoor baseline)
        origin_z: 0.0
        z_resolution: 0.05
        z_voxels: 16                      # ~0.8m vertical at 5cm resolution
        unknown_threshold: 15
        mark_threshold: 0

        # Height filtering: include low tables, exclude floor noise
        min_obstacle_height: 0.05
        max_obstacle_height: 1.20

        # Observation sources (PointCloud2)
        # Baseline: LiDAR deskewed cloud (360°). Optional: add RealSense cloud.
        observation_sources: "lidar_cloud"

        lidar_cloud:
          topic: "(*@\LidarCloudTopic@*)"
          data_type: "PointCloud2"
          marking: true
          clearing: true
          obstacle_range: 8.0
          raytrace_range: 10.0
          min_obstacle_height: 0.05
          max_obstacle_height: 1.20

        # Optional second source (uncomment if you want to fuse D415 pointcloud)
        # realsense_cloud:
        #   topic: <REALSENSE_CLOUD_TOPIC>
        #   data_type: "PointCloud2"
        #   marking: true
        #   clearing: true
        #   obstacle_range: 4.0
        #   raytrace_range: 5.0
        #   min_obstacle_height: 0.05
        #   max_obstacle_height: 1.20

      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        inflation_radius: 0.60
        cost_scaling_factor: 5.0

